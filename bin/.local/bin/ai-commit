#!/usr/bin/env bash
#
# AI-powered conventional commit message generator
# Uses claude CLI to generate commit messages from staged changes
#
# Usage: ai-commit
#
# Prerequisites: claude CLI (npm i -g @anthropic-ai/claude-code)
#
# Behavior:
#   1. Checks for staged changes
#   2. Pipes diff to claude CLI for message generation
#   3. Presents message for user confirmation
#   4. Commits with the generated message

set -euo pipefail

if ! command -v claude >/dev/null 2>&1; then
	echo "Error: claude CLI not installed." >&2
	echo "Install: npm i -g @anthropic-ai/claude-code" >&2
	exit 1
fi

# Check for staged changes
if git diff --cached --quiet 2>/dev/null; then
	echo "Error: No staged changes. Run 'git add' first." >&2
	exit 1
fi

diff_output=$(git diff --cached --stat)
diff_patch=$(git diff --cached)

prompt="Generate a conventional commit message for these staged changes. Use the format: <type>: <description>

Types: feat, fix, refactor, docs, test, chore, perf, ci

Rules:
- Keep the first line under 72 characters
- Focus on WHY, not WHAT
- Be concise (1-2 sentences max)
- Output ONLY the commit message, nothing else

Changes summary:
${diff_output}

Full diff:
${diff_patch}"

echo "Generating commit message..."
claude_stderr=$(mktemp)
message=$(echo "${prompt}" | claude --print 2>"${claude_stderr}")

if [[ -z "${message}" ]]; then
	echo "Error: Failed to generate commit message." >&2
	[[ -s "${claude_stderr}" ]] && cat "${claude_stderr}" >&2
	rm -f "${claude_stderr}"
	exit 1
fi
rm -f "${claude_stderr}"

echo ""
echo "Generated commit message:"
echo "─────────────────────────"
echo "${message}"
echo "─────────────────────────"
echo ""

read -r -p "Use this message? [Y/n/e(dit)] " response
case "${response,,}" in
n | no)
	echo "Commit cancelled."
	exit 0
	;;
e | edit)
	git commit -e -m "${message}"
	;;
*)
	git commit -m "${message}"
	;;
esac
